{
  "name": "research-support-hub",
  "version": "1.0.0",
  "description": "CSSWENG Research Support Hub Web App",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "dev": "node server",
    "preview": "cross-env NODE_ENV=production node server",
    "build": "npm run handlebars && npm run build:client && npm run build:server",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.js --outDir dist/server",
    "handlebars": "npx handlebars src/templates/ -e hbs -f src/compiled-templates.js && node custom_utils/handlebars-precompile.js",
    "standard": "standard --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Aspyse/research-support-hub.git"
  },
  "keywords": [
    "firebase",
    "express",
    "handlebars"
  ],
  "author": "1233 CSSWENG S16 Group 10",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Aspyse/research-support-hub/issues"
  },
  "homepage": "https://github.com/Aspyse/research-support-hub#readme",
  "dependencies": {
    "compression": "^1.7.4",
    "express": "^4.19.2",
    "sirv": "^2.0.4"
  },
  "devDependencies": {
    "child_process": "^1.0.2",
    "chokidar": "^3.6.0",
    "cross-env": "^7.0.3",
    "handlebars": "^4.7.8",
    "standard": "^17.1.0",
    "vite": "^5.2.10"
  },
  "standard": {
    "ignore": [
      "/dist/"
    ]
  }
}
